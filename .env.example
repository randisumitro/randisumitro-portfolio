# ============================================================
# Environment Variables — Randi Sumitro Portfolio
# Copy this file to .env.local and fill in your values
# ============================================================

# GitHub Personal Access Token (optional - increases API rate limit from 60 to 5000 req/hour)
# How to get: https://github.com/settings/tokens/new
# Required scopes: public_repo, read:user
GITHUB_TOKEN=your_github_personal_access_token_here

# Resend API Key (for contact form email)
# How to get: https://resend.com → Sign up → API Keys
# Free tier: 3000 emails/month
RESEND_API_KEY=your_resend_api_key_here

# Site URL
NEXT_PUBLIC_SITE_URL=https://randisumitro.vercel.app
